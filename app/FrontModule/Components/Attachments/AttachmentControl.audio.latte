<div class="attachment noprint">
	<audio controls preload="auto">
		<source n:foreach="$attachment->files as $file" src="{$file|webPath}">
	</audio>

	<div class="attachment--download">
		<span class="fa fa-download" title="Stáhnout"></span>
		{foreach $attachment->files as $file}
			<a href="{plink File: $file}">{$file->getExtension()|upper}</a> ({$file->fileSize|bytes})
			{sep} &bull; {/sep}
		{/foreach}
	</div>
</div>
