<!doctype html>
<html>
{control head}

<body>
<div class="container">
	<div class="menu noprint">
		<ul>
			<li><a n:href="Dashboard:" n:class="$presenter->isLinkCurrent('Dashboard:*') ? active">Dashboard</a></li>
			<li><a n:href="Post:" n:class="$presenter->isLinkCurrent('Post:*') ? active">Posts</a></li>
			<li><a n:href="Category:" n:class="$presenter->isLinkCurrent('Category:*') ? active">Categories</a></li>
			<li><a n:href="Event:" n:class="$presenter->isLinkCurrent('Event:*') ? active">Events</a></li>
			<li><a n:href="Newsletter:" n:class="$presenter->isLinkCurrent('Newsletter:*') ? active">Newsletter</a></li>
		</ul>
	</div>

	<div class="sep"></div>

	{if isset($presenter['flashes'])}{control flashes}{/if}
	{include #content}
</div>
</body>
</html>
